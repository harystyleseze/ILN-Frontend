{
  "ci": {
    "collect": {
      "numberOfRuns": 3,
      "startServerCommand": "npm run build && npm start",
      "startServerReadyPattern": "Ready in",
      "startServerReadyTimeout": 120000,
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/marketplace",
        "http://localhost:3000/dashboard/lp",
        "http://localhost:3000/governance"
      ],
      "settings": {
        "preset": "desktop",
        "throttlingMethod": "simulate",
        "throttling": {
          "rttMs": 40,
          "throughputKbps": 10240,
          "cpuSlowdownMultiplier": 1
        }
      }
    },
    "assert": {
      "assertions": {
        "largest-contentful-paint": ["error", { "maxNumericValue": 2500 }],
        "first-input-delay": ["error", { "maxNumericValue": 100 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "total-byte-weight": ["error", { "maxNumericValue": 204800 }],
        "interactive": ["warn", { "maxNumericValue": 3800 }],
        "first-contentful-paint": ["warn", { "maxNumericValue": 1800 }],
        "uses-text-compression": ["warn", { "minScore": 0.8 }],
        "render-blocking-resources": ["warn", { "maxLength": 2 }],
        "unused-javascript": ["warn", { "maxNumericValue": 204800 }],
        "categories:performance": ["warn", { "minScore": 0.7 }],
        "categories:accessibility": ["warn", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.8 }],
        "categories:seo": ["warn", { "minScore": 0.8 }]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci",
      "reportFilenamePattern": "%%PATHNAME%%-%%DATETIME%%-report.%%EXTENSION%%"
    }
  }
}